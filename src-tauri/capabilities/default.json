{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "upload:default",
    "fs:default",
    "fs:allow-app-meta",
    "fs:allow-app-meta-recursive",
    {
      "identifier": "http:default",
      "allow": ["http://localhost:8080/*"]
    }
  ]
}
